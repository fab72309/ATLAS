# Copiez ce fichier en `.env` ou `.env.local` puis remplissez les valeurs.

# --- Supabase (obligatoire pour le client) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Météo (optionnel pour la fonctionnalité météo du zonage) ---
# Clé depuis https://www.weatherapi.com/ (gratuit)
VITE_WEATHER_API_KEY=

# --- OpenAI via proxy (obligatoire en prod) ---
# Mettez l'URL HTTPS de votre proxy `analyze`.
# Local recommandé: http://127.0.0.1:8787/analyze
VITE_OPENAI_PROXY_URL=

# --- Contournement local DEV (optionnel) ---
# Permet de tester l'app sans Supabase local. N'activer qu'en développement.
# Vous pouvez aussi l'activer depuis l'écran de connexion via "Continuer en mode dev".
VITE_DEV_AUTH_BYPASS=false

# La clé OpenAI reste côté serveur (proxy / .env.proxy).

# --- Carto (optionnel, fallback en code) ---
VITE_MAPTILER_KEY=
VITE_OFFLINE_TILE_URL=
VITE_OFFLINE_SOURCE_LAYER=
